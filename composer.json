{
  "name": "ynamite/viterex",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Ynamite\\ViteRex\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ynamite\\ViteRex\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.3.24"
    }
  }
}
