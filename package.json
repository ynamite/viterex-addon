{
  "name": "viterex-assets",
  "version": "2.0.0",
  "description": "Asset build for ViteRex Addon",
  "scripts": {
    "version:sync": "node scripts/sync-version.js",
    "prebuild": "npm run version:sync && npm run clean:assets",
    "build": "vite build && rsync -a assets/. ../../../public/assets/addons/viterex/",
    "build:css": "vite build --mode css",
    "build:js": "vite build --mode js",
    "watch": "vite build --watch",
    "dev": "concurrently \"vite build --watch\" \"npm run clean:assets\" \"npm run sync\"",
    "clean:assets": "rm -f ../../../public/assets/addons/viterex/*",
    "sync": "chokidar 'assets/**/*' -c 'rsync -a assets/. ../../../public/assets/addons/viterex/'",
    "preview": "vite preview",
    "clean": "rm -rf assets dist node_modules/.vite",
    "update-deps": "npm update"
  },
  "dependencies": {},
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "js-yaml": "^4.1.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "stylelint": "^16.23.0",
    "stylelint-config-standard": "^39.0.0",
    "vite": "^7.0.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "private": true
}
