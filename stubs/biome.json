{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"includes": ["**/*.{js,mjs,cjs,jsx,ts,tsx,json,jsonc}"],
		"ignore": [
			"node_modules",
			"vendor",
			"redaxo",
			"public/assets/addons",
			"theme/public/assets/addons",
			"assets/addons"
		]
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
