# ViteRex environment defaults.
# Copy this file to `.env` and edit as needed; also add `.env.local`, `.env.development`,
# or `.env.production` — viterex-addon loads all of them in that order.

# Vite dev server (used when the hot file is missing; leave blank to disable the HTTP probe fallback).
VITE_DEV_SERVER=http://localhost
VITE_DEV_SERVER_PORT=5173

# Default entry file, resolved from project root.
VITE_ENTRY_POINT=src/Main.js

# HTTPS dev server. To enable, run `mkcert localhost 127.0.0.1 ::1` in the project root,
# then set this to `true`. If the cert files are missing the config silently falls back to http.
VITE_HTTPS=false

# Structure override. One of: classic | modern | theme. Auto-detected when unset.
# VITE_STRUCTURE=modern

# Build path overrides. The defaults are structure-aware and almost always correct.
# VITE_OUTPUT_DIR=/public/assets/addons/viterex
# VITE_DIST_URL=/assets/addons/viterex
